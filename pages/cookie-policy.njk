                    class="govuk-body-s"
                    style="font-weight:700; text-transform:uppercase; letter-spacing:0.05em; margin-bottom:0.75rem;">On this page</p>
                <ol class="govuk-list" style="border-left:4px solid #b1b4b6; padding-left:1rem;">
                    <li style="margin-bottom:0.5rem;">
                        <a class="govuk-link" href="#change-your-cookie-settings">Change your cookie settings</a>
                    </li>
                    <li style="margin-bottom:0.5rem;">
                        <a class="govuk-link" href="#cookies-on-food-gov-uk">Cookies on food.gov.uk and ratings.food.gov.uk</a>
                    </li>
                    <li style="margin-bottom:0.5rem;">
                        <a class="govuk-link" href="#cookies-on-other-fsa-websites">Cookies on other FSA websites</a>
                    </li>
                    <li style="margin-bottom:0.5rem;">
                        <a class="govuk-link" href="#cookies-on-sac-sites">Cookies on Scientific Advisory Committees sites</a>
                    </li>
                </ol>
            </nav>
        </div>
        {# ── Main content ─────────────────────────────────────────────────── #}
        <div
            class="govuk-grid-column-two-thirds">
            {# Toolbar #}
            <div class="govuk-grid-column-full;">
                <h1 class="govuk-heading-xl govuk-!-margin-bottom-4">Cookie policy</h1>
            </div>
            <div style="display:flex; align-items:center; justify-content:space-between; border-bottom:1px solid #b1b4b6;
                    padding-bottom:1rem; margin-bottom:1.5rem; flex-wrap:wrap; gap:1rem;">
                <div>
                    <p class="govuk-body-s govuk-!-margin-bottom-0">Last updated: 4 July 2025</p>
                    <a class="govuk-link govuk-body-s" href="#revision-log">See all updates</a>
                </div>
                <div style="display:flex; gap:1rem; align-items:center;">
                    <a
                        href="/new/cookie-policy?format=pdf"
                        style="display:flex; align-items:center; gap:0.5rem; font-weight:700; text-decoration:none; color:#007c75;
                            font-family:inherit; font-size:1rem;"
                        target="_blank"
                        rel="noopener">
                        <span style="display:inline-flex; align-items:center; justify-content:center; width:40px; height:40px; border-radius:50%;
                                background:#007c75; flex-shrink:0;">
                            <svg
                                xmlns="http://www.w3.org/2000/svg"
                                width="18"
                                height="18"
                                viewBox="0 0 24 24"
                                fill="none"
                                stroke="#fff"
