                        View as PDF
                    </a>
                    <button
                        onclick="window.print()"
                        style="display:flex; align-items:center; gap:0.5rem; font-weight:700; background:none; border:none; cursor:pointer;
                            color:#007c75; font-size:1rem; font-family:inherit; padding:0; text-decoration:underline;">
                        <span style="display:inline-flex; align-items:center; justify-content:center; width:40px; height:40px; border-radius:50%;
                                background:#007c75; flex-shrink:0;">
                            <svg
                                xmlns="http://www.w3.org/2000/svg"
                                width="18"
                                height="18"
                                viewBox="0 0 24 24"
                                fill="none"
                                stroke="#fff"
                                stroke-width="2.5"
                                stroke-linecap="round"
                                stroke-linejoin="round"
                                aria-hidden="true"><polyline points="6 9 6 2 18 2 18 9"/><path d="M6 18H4a2 2 0 0 1-2-2v-5a2 2 0 0 1 2-2h16a2 2 0 0 1 2 2v5a2 2 0 0 1-2 2h-2"/><rect x="6" y="14" width="12" height="8"/>
