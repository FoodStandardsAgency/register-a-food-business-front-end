{% macro govukCustomHeader(params) %}
<header class="govuk-header govuk-header--full-width-border">
  <div class="govuk-header__container govuk-width-container app-width-container app-header-container">
    <div class="govuk-header__logo app-header-logo">   
        <span class="govuk-header__product-name">
          {{ params.serviceName }}
        </span> 
    </div>
  </div>
</header>
{% endmacro %}